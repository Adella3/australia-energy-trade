                              <run>Æ&#10;</run>
                              <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>(2007)</run>
                            </formatted-text>
                            <point>
                              <visual-coordinate class='axis'>
                                <x-coord cell-offset='0.62805'>
