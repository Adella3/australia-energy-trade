          <zone h='98568' id='1' param='vert' removable='false' type-v2='layout-flow' w='99212' x='394' y='716'>
            <zone h='2954' id='3' type-v2='title' w='99212' x='394' y='716' />
            <zone fixed-size='158' h='14145' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99212' x='394' y='3670' />
            <zone h='81469' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99212' x='394' y='17815'>
              <flipboard active-id='4' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Australia’s Energy Imports in Mineral Fuels: Petroleum dominates, accounting for ~97% of total imports in this category' captured-sheet='Storyboard_1' id='1' />
                  <story-point caption='Import vs Export Comparision Overview. This comparison highlights the stark contrast between petroleum imports and coal/gas exports.' captured-sheet='Storyboard_2' id='2' />
                  <story-point caption='A big-picture look: Exports of coal and gas drive Australia&apos;s energy trade, while petroleum imports spike during crises (e.g., GFC 2008, Russia-Ukraine 2022)' captured-sheet='Storyboard_3' id='4'>
                    <capturedDeltas>
                      <worksheet name='Main Category_3 Mineral Fuels, Lubricants and related materials_Export &amp; Import Stacked bar'>
                        <annotations>
