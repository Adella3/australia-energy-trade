                        </annotations>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Top Petroleum Import Years. Petroleum imports peaked in 2022–2024, reflecting Australia’s energy dependency during global disruptions.' captured-sheet='Sheet 29' id='5' />
                  <story-point caption='Export Ratios Across Subcategories(Coal, Petroleum, Gas)' captured-sheet='Main Category_3 Mineral Fuels, Lubricants and related materials (4)' id='3' />
