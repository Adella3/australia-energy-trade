                          </annotation>
                          <annotation class='point' delta-type='added' id='1' mark-position='1' pullback='0' text-width='180'>
                            <formatted-text>
                              <run bold='true' fontname='Benton Sans Book'>COVID-19 Pandemic</run>
                              <run>Æ&#10;</run>
                              <run bold='true' fontname='Benton Sans Book'>(2020)</run>
                            </formatted-text>
                            <point>
                              <visual-coordinate class='axis'>
                                <x-coord cell-offset='0.50243'>
                                  <node-reference>
                                    <fields>
